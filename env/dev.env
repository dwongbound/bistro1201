# Instance selection
APP_INSTANCE=dev
FRONTEND_NODE_ENV=development

# Public ports
FRONTEND_HOST_PORT=5173
BACKEND_HOST_PORT=3000
NGINX_HOST_PORT=80

# Frontend runtime/build config
APP_API_BASE_PATH=/api
APP_R2_BASE_URL=https://cdn.1201bistrocafe.com
DEV_API_PROXY_TARGET=http://backend:3000
E2E_BASE_URL=http://nginx

# Backend runtime config
PORT=3000
POSTGRES_DB=bistro1201
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/bistro1201
GUEST_ACCESS_CODE=bistro1201
GUEST_ACCESS_CODE_EXPIRES_AT=
STAFF_ACCESS_CODE=service1201

# Object storage (MinIO for dev, Cloudflare R2 for prod)
R2_ENDPOINT_URL=http://minio:9000
R2_BUCKET=bistro1201
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin

# Email delivery — points at local Mailpit catch-all for dev (http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=test
SMTP_PASSWORD=test
SMTP_FROM_ADDRESS=reservations@1201bistrocafe.com
SMTP_FROM_NAME=1201 Bistro
